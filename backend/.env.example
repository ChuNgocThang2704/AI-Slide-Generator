### Primary LLM (text/chart)
LLM_MODEL=Qwen3-8B
VLLM_API_BASE_URL=http://127.0.0.1:8001
VLLM_TIMEOUT_SEC=300

### Fallback LLM (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TIMEOUT_SEC=120

### Primary image model (SDXL self-host)
IMAGE_GEN_API_BASE_URL=http://127.0.0.1:8080
IMAGE_GEN_API_KEY=
IMAGE_GEN_TIMEOUT_SEC=600

### Fallback image model (Together FLUX)
IMAGE_FALLBACK_API_BASE_URL=https://api.together.ai
IMAGE_FALLBACK_API_KEY=
IMAGE_FALLBACK_MODEL=black-forest-labs/FLUX.1-schnell
IMAGE_FALLBACK_TIMEOUT_SEC=180

### Quality gates
IMAGE_CLIP_VALIDATE_ENABLE=true
IMAGE_CLIP_MIN_SCORE=0.22
IMAGE_VLM_JUDGE_ENABLE=true
IMAGE_VLM_JUDGE_MODEL=gemini-2.0-flash
IMAGE_VLM_JUDGE_MIN_RELEVANCE=0.60
IMAGE_VLM_JUDGE_MAX_ARTIFACT=0.45
IMAGE_VLM_JUDGE_TIMEOUT_SEC=25
